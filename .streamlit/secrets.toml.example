# Example secrets file for Streamlit Cloud
# Copy this to .streamlit/secrets.toml and fill in your values
# DO NOT commit secrets.toml to git!

# Database connection
# For Supabase, use the connection pooler URL (port 6543) instead of direct connection (port 5432)
# This helps with IPv6/IPv4 issues and connection limits
DATABASE_URI = "postgresql://user:password@db.project.supabase.co:6543/postgres"

# API Keys (optional - can be entered in the UI)
# OPENAI_API_KEY = "sk-..."
# ANTHROPIC_API_KEY = "sk-ant-..."
# GOOGLE_API_KEY = "..."
